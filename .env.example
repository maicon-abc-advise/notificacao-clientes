# Copie para .env e ajuste os valores (nunca faça commit do arquivo .env).
API_KEY=dev-change-me
REDIS_URL=redis://localhost:6379/0
WEBHOOK_SECRET=
LOG_LEVEL=INFO

# --- Ambiente local (venv) ---
# py -3.12 -m venv .venv
# .\.venv\Scripts\pip install -e ".[dev]"
# Suba o Redis (por exemplo: docker compose up -d redis) quando for integrar Redis no código.
# .\.venv\Scripts\uvicorn app.main:app --reload --host 127.0.0.1 --port 8000

# --- Docker (API + Redis) ---
# docker compose up --build
# Documentação interativa (Swagger): http://127.0.0.1:8000/docs
