REENVIO_SMS_REPROCESSAR_MAX=10

# true = ativa POST /v1/interno/teste-pipeline/* (simula e-mail/SMS sem Zenvia)
TESTE_PIPELINE_HABILITADO=false

MENSAGENS_PROVEDOR_EMAIL=zenvia
MENSAGENS_PROVEDOR_SMS=zenvia

ZENVIA_API_BASE_URL=
ZENVIA_API_TOKEN=
