# =============================================================================
# VARIÁVEIS GERAIS
# =============================================================================

# AMBIENTE: local | producao (também dev, prod, produção)
AMBIENTE=local

MOCK_COMPANY_PROFILE_ENRIQUECIMENTO=true
USE_ZENVIA_MOCK=true


SWEEP_EMAILS_ESPERANDO_CONFIRMACAO_DIAS=2
REENVIO_SMS_REPROCESSAR_MAX=10

# Job POST /v1/interno/orquestracao/verificar-creditos (coluna fornecedores.creditos)
LIMIAR_CREDITOS_NO_FIM=5
LINK_AREA_CREDITOS=https://buscafornecedor.com.br/creditos

# Busca: {{ url_login }} = URL_BASE_CLIQUE + / + token (12 chars, cifrado com LINK_CLIQUE_SECRET). Front /c/{token} → GET /v1/clique/{token}
URL_BASE_CLIQUE_TEST=http://127.0.0.1:8000/v1/clique
URL_BASE_CLIQUE_PROD=https://buscafornecedor.com.br/c
URL_LANDING_INFO_CONSULTA=https://buscafornecedor.com.br/info-consulta
LINK_CLIQUE_SECRET=change-me-clique-secret

LOG_LEVEL=INFO
API_KEY=dev-change-me

DASHBOARD_LOGIN=
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_TTL=3600
DASHBOARD_COOKIE_NAME=dashboard_session

CORS_ORIGINS=http://localhost:5173,https://buscafornecedor.com.br,https://www.buscafornecedor.com.br

# =============================================================================
# VARIÁVEIS LOCAIS (dados / cache de desenvolvimento)
# =============================================================================
REDIS_URL_TEST=redis://localhost:6379/0
DATABASE_URL_TEST=postgresql://notificacao:notificacao_dev@127.0.0.1:5433/notificacao

# Schema Postgres (namespace). Tabelas sem sufixo extra ficam schema.nome.
POSTGRES_SCHEMA=
# Sufixo em consultas e em usuario_fornecedor (ex.: _teste → consultas_teste, usuario_fornecedor_teste; PK da tabela é ``id``).
# Nas demais tabelas, colunas FK para esse usuário usam fornecedor_id + sufixo quando o sufixo não é vazio (ex.: fornecedor_id_teste).
POSTGRES_TABELA_SUFFIX=

# =============================================================================
# VARIÁVEIS DE PRODUÇÃO (dados / cache em produção)
# =============================================================================
REDIS_URL_PROD=
DATABASE_URL_PROD=

MENSAGENS_PROVEDOR_EMAIL=zenvia
MENSAGENS_PROVEDOR_SMS=zenvia

ZENVIA_API_BASE_URL_PROD=https://api.zenvia.com
ZENVIA_API_TOKEN_PROD=
ZENVIA_EMAIL_FROM_PROD=
ZENVIA_SMS_FROM_PROD=
ZENVIA_WEBHOOK_SECRET_PROD=

# Vapi (ligações de voz — debug / outbound)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

