API_KEY=dev-change-me
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://notificacao:notificacao_dev@127.0.0.1:5433/notificacao
LOG_LEVEL=INFO

# E-mails em Redis (namespace emails-esperando-confirmacao); ainda aceita SWEEP_EMAIL_PENDENTE_DIAS
